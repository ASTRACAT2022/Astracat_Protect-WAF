# syntax=docker/dockerfile:1
FROM golang:1.24-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go env -w GOPROXY=https://proxy.golang.org,direct
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg/mod \
    go mod download
COPY . .
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg/mod \
    CGO_ENABLED=0 go build -o /out/astracat-protect ./cmd/astracat-protect

FROM python:3.11-slim

# Runtime tools for hook commands.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates bash \
    && rm -rf /var/lib/apt/lists/*

# Optional ML runtimes:
# default is onnxruntime only (most stable).
# for TFLite try: --build-arg AI_PIP_PACKAGES="onnxruntime tflite-runtime"
ARG AI_PIP_PACKAGES="onnxruntime"
RUN pip install --no-cache-dir ${AI_PIP_PACKAGES}

RUN adduser -D -u 10001 app
USER app
WORKDIR /app

COPY --from=build /out/astracat-protect /app/astracat-protect
COPY deploy/ai-hooks /app/ai-hooks

EXPOSE 80 443 9090
VOLUME ["/data"]
ENTRYPOINT ["/app/astracat-protect"]
